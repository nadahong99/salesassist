# ─────────────────────────────────────────────
#  SalesAssist – 환경변수 예시 (.env.example)
#  실제 사용 시: 이 파일을 .env 로 복사하고 값을 수정하세요.
#  cp .env.example .env
# ─────────────────────────────────────────────

# 서버 바인드 주소 (로컬: 127.0.0.1, 클라우드/외부 접속: 0.0.0.0)
HOST=0.0.0.0

# 서버 포트 (Render/Heroku 등 클라우드에서는 $PORT 를 자동 주입)
PORT=8000

# 데이터 저장 디렉토리 (비어 있으면 ./data 사용)
# Render 무료 플랜: /tmp/data (재시작 시 초기화됨)
# Render 유료 플랜: /var/data (영구 디스크 마운트 경로)
DATA_DIR=

# CORS 허용 출처 (쉼표 구분, * 이면 전체 허용)
# 프론트엔드와 백엔드 도메인이 다를 때 보안상 명시 권장
# ALLOWED_ORIGINS=https://salesassist.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=*
